# Next.js public URL (used for sharing links in blog posts)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Remote JSON content source.
# If CONTENT_REMOTE_BASE_URL is unset, the app builds Cloudinary raw URLs from
# CLOUDINARY_CLOUD_NAME and CONTENT_CLOUDINARY_FOLDER.
CONTENT_REMOTE_BASE_URL=
CONTENT_CLOUDINARY_FOLDER=portfolio-content

# Password for /admin/content. Keep these server-only.
CONTENT_ADMIN_PASSWORD=
CONTENT_ADMIN_SESSION_SECRET=

# Cloudinary credentials used only by server-side admin API routes.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
