# Data source: "api" (default) fetches from BASE_URL; "json" reads from local data/*.json files
DATA_SOURCE=api

# Required when DATA_SOURCE=api
BASE_URL=https://your-api-url.example.com

# Next.js public URL (used for sharing links in blog posts)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Google Analytics (Optional)
# GOOGLE_ANALYTICS_ID=UA-XXXXXXX-X
